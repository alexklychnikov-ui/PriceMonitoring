        {
          "datasource": {"type": "postgres", "uid": "priceMonitor"},
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', a.triggered_at) AS \"time\",\n  COUNT(*)::double precision AS alerts\nFROM alerts a\nJOIN products p ON p.id = a.product_id\nJOIN sites s ON s.id = p.site_id\nWHERE a.triggered_at >= NOW() - INTERVAL '7 days'\n  AND a.alert_type IN ('price_drop','price_rise','price_changed','new_low')\n  AND s.is_active = true\nGROUP BY 1\nORDER BY 1",
          "refId": "A"
        }
      ],
