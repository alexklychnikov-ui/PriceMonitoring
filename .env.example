DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/price_monitor
REDIS_URL=redis://localhost:6379/0

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_CHANNEL_ID=@your_telegram_channel
# Опционально: если задано, API /products/*/subscription требует заголовок X-Subscription-Key (тот же ключ в бандл фронта через vite loadEnv из корня)
SUBSCRIPTION_WEB_KEY=

LLM_PROVIDER=openai
# https://proxyapi.ru — без ключа weekly report и AI-ответы падают в fallback (401)
PROXY_API_KEY=your_proxyapi_key
PROXY_BASE_URL=https://openai.api.proxyapi.ru/v1
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

PROXY_LIST=http://127.0.0.1:12334,http://127.0.0.1:12335
PARSE_INTERVAL_HOURS=6
PRICE_ALERT_THRESHOLD_PCT=5.0
# Удалять products без in_stock=true в price_history дольше N дней (нет активных подписок)
PRUNE_PRODUCTS_INACTIVE_DAYS=90

FLOWER_USER=admin
FLOWER_PASSWORD=secure_password
GRAFANA_PASSWORD=secure_password
DOMAIN_NAME=monitor.local
PUBLIC_SITE_URL=
CORS_ORIGINS=http://localhost:5173,https://monitor.local
TELEGRAM_BOT_USERNAME=
